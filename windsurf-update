#!/usr/bin/env bash
#
# windsurf-update - Automated Windsurf Editor updater for Shani OS (tarball install)
#
# Usage:
#   windsurf-update check      - Check if a newer version is available
#   windsurf-update install    - Download and install latest version
#   windsurf-update rollback   - Restore the previous backup installation
#   windsurf-update help       - Show this help
#

set -euo pipefail

# ============================================================================
# CONFIGURATION
# ============================================================================

INSTALL_DIR="${HOME}/.var/app/Windsurf"
BACKUP_DIR="${HOME}/.var/app/Windsurf_old"
TEMP_DIR="/tmp/windsurf-update-$$"
LOG_FILE="${HOME}/.config/windsurf-update.log"

DOWNLOAD_URL="https://windsurf.com/api/windsurf/download-redirect?build=linux-x64&isNext=false"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# ============================================================================
# LOGGING
# ============================================================================

log() {
    local level="$1"; shift
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [${level}] $*" >> "${LOG_FILE}" || true
}

info()    { echo -e "${BLUE}[INFO]${NC}  $*";    log "INFO"    "$*"; }
success() { echo -e "${GREEN}[OK]${NC}    $*";   log "SUCCESS" "$*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*";   log "WARN"    "$*"; }
error()   { echo -e "${RED}[ERR]${NC}   $*" >&2; log "ERROR"   "$*"; }

# ============================================================================
# CLEANUP TRAP
# ============================================================================

cleanup() {
    if [[ -d "${TEMP_DIR}" ]]; then
        rm -rf "${TEMP_DIR}"
    fi
}
trap cleanup EXIT

# ============================================================================
# VERSION HELPERS
# ============================================================================

# Read version directly from product.json (the authoritative source)
get_current_version() {
    local product_json="${INSTALL_DIR}/resources/app/product.json"
    if [[ -f "${product_json}" ]]; then
        grep -oP '"windsurfVersion":\s*"\K[^"]+' "${product_json}"
    else
        echo "0.0.0"
    fi
}

# Get the latest version by following the download redirect URL.
# The redirect resolves to a URL like: .../Windsurf-linux-x64-2.0.67.tar.gz
# This is reliable and returns exactly one version string.
get_latest_version() {
    local effective_url version
    effective_url=$(curl -fsSL --max-time 15 -o /dev/null \
        -w "%{url_effective}" "${DOWNLOAD_URL}" 2>/dev/null)
    version=$(printf '%s' "${effective_url}" \
        | grep -oP '(?<=-)[0-9]+\.[0-9]+\.[0-9]+(?=\.tar\.gz)')
    if [[ -z "${version}" ]]; then
        error "Could not determine version from redirect URL: ${effective_url}"
        return 1
    fi
    echo "${version}"
}

# Returns 0 (true) if $1 is strictly less than $2 by version ordering
# Uses sort -V. Avoids `head -1` pipe to prevent SIGPIPE under pipefail.
version_lt() {
    if [[ "$1" == "$2" ]]; then
        return 1
    fi
    local sorted first
    sorted=$(printf '%s\n%s\n' "$1" "$2" | sort -V)
    first="${sorted%%$'\n'*}"
    [[ "${first}" == "$1" ]]
}

# ============================================================================
# CHECK
# ============================================================================

do_check() {
    local current latest

    info "Reading installed version..."
    current=$(get_current_version)
    info "Installed : ${BOLD}${current}${NC}"

    info "Fetching latest version..."
    if ! latest=$(get_latest_version); then
        return 1
    fi
    info "Latest    : ${BOLD}${latest}${NC}"

    if version_lt "${current}" "${latest}"; then
        echo -e "\n${YELLOW}${BOLD}Update available:${NC} ${current} → ${latest}"
        echo -e "Run: ${BOLD}windsurf-update install${NC} to update.\n"
    else
        success "Windsurf is up to date (${current})."
    fi
    return 0
}

# ============================================================================
# INSTALL
# ============================================================================

do_install() {
    local current latest tarball new_dir

    current=$(get_current_version)
    info "Installed : ${current}"

    info "Fetching latest version..."
    if ! latest=$(get_latest_version); then
        return 1
    fi
    info "Latest    : ${latest}"

    if ! version_lt "${current}" "${latest}"; then
        success "Already up to date (${current}). Nothing to do."
        return 0
    fi

    echo -e "\n${BOLD}Updating Windsurf: ${current} → ${latest}${NC}\n"

    # Prepare temp workspace (PID-namespaced to avoid conflicts)
    mkdir -p "${TEMP_DIR}"

    # ── Step 1: Download ─────────────────────────────────────────────────────
    tarball="${TEMP_DIR}/windsurf.tar.gz"
    info "Downloading Windsurf ${latest} (this may take a while)..."
    if ! curl -fSL --progress-bar --max-time 600 "${DOWNLOAD_URL}" -o "${tarball}"; then
        error "Download failed."
        return 1
    fi

    # Verify it's a real gzip archive (not an HTML error page)
    if ! file "${tarball}" | grep -q "gzip compressed data"; then
        error "Downloaded file is not a valid tar.gz. Download may have failed silently."
        rm -f "${tarball}"
        return 1
    fi
    success "Download complete."

    # ── Step 2: Extract ──────────────────────────────────────────────────────
    new_dir="${TEMP_DIR}/Windsurf-new"
    mkdir -p "${new_dir}"
    info "Extracting archive..."
    if ! tar -xzf "${tarball}" -C "${new_dir}" --strip-components=1; then
        error "Extraction failed."
        return 1
    fi

    # Verify key files exist after extraction
    if [[ ! -f "${new_dir}/windsurf" ]] || [[ ! -f "${new_dir}/bin/windsurf" ]]; then
        error "Expected binaries not found after extraction. Aborting."
        return 1
    fi
    chmod +x "${new_dir}/windsurf" "${new_dir}/bin/windsurf"
    success "Extraction complete."

    # ── Step 3: Backup current install (instant mv rename, not cp) ───────────
    info "Backing up current installation..."
    if [[ -d "${BACKUP_DIR}" ]]; then
        rm -rf "${BACKUP_DIR}"
    fi
    if [[ -d "${INSTALL_DIR}" ]]; then
        if ! mv "${INSTALL_DIR}" "${BACKUP_DIR}"; then
            error "Backup failed. Aborting to protect current installation."
            return 1
        fi
        success "Backup saved → ${BACKUP_DIR}"
    fi

    # ── Step 4: Install new version (instant mv rename) ──────────────────────
    info "Installing Windsurf ${latest}..."
    if ! mv "${new_dir}" "${INSTALL_DIR}"; then
        error "Install failed. Rolling back to ${current}..."
        if mv "${BACKUP_DIR}" "${INSTALL_DIR}"; then
            warn "Rollback successful. Still on version ${current}."
        else
            error "ROLLBACK ALSO FAILED. Manual recovery needed:"
            error "  mv ${BACKUP_DIR} ${INSTALL_DIR}"
        fi
        return 1
    fi

    # ── Step 5: Verify installed version ─────────────────────────────────────
    local installed_version
    installed_version=$(get_current_version)
    if [[ "${installed_version}" != "${latest}" ]]; then
        warn "Installed version (${installed_version}) doesn't match expected (${latest})."
    fi

    echo ""
    success "Windsurf updated: ${current} → ${installed_version}"
    info "Restart Windsurf to use the new version."
    echo ""
}

# ============================================================================
# ROLLBACK
# ============================================================================

do_rollback() {
    if [[ ! -d "${BACKUP_DIR}" ]]; then
        error "No backup found at ${BACKUP_DIR}. Cannot rollback."
        return 1
    fi

    local backup_version
    backup_version=$(grep -oP '"windsurfVersion":\s*"\K[^"]+' \
        "${BACKUP_DIR}/resources/app/product.json" 2>/dev/null || echo "unknown")

    local current_version
    current_version=$(get_current_version)

    warn "Rolling back: ${current_version} → ${backup_version}"

    if [[ -d "${INSTALL_DIR}" ]]; then
        rm -rf "${INSTALL_DIR}"
    fi
    if mv "${BACKUP_DIR}" "${INSTALL_DIR}"; then
        success "Rollback complete. Now on: ${backup_version}"
        info "Restart Windsurf to use the restored version."
    else
        error "Rollback failed. Backup remains at: ${BACKUP_DIR}"
        return 1
    fi
}

# ============================================================================
# USAGE
# ============================================================================

usage() {
    cat <<EOF

${BOLD}windsurf-update${NC} — Windsurf tarball updater for Shani OS

${BOLD}USAGE:${NC}
  windsurf-update <command>

${BOLD}COMMANDS:${NC}
  check      Check if a newer version is available (no changes made)
  install    Download and install the latest version
  rollback   Restore the previous backup installation
  help       Show this help

${BOLD}FILES:${NC}
  Install dir  : ${INSTALL_DIR}
  Backup dir   : ${BACKUP_DIR}
  Log file     : ${LOG_FILE}

EOF
}

# ============================================================================
# ENTRY POINT
# ============================================================================

case "${1:-help}" in
    check)             do_check    ;;
    install)           do_install  ;;
    rollback)          do_rollback ;;
    help|--help|-h)    usage       ;;
    *)
        error "Unknown command: '$1'"
        usage
        exit 1
        ;;
esac
